@router.callback_query(F.data.startswith("admin:"))
async def admin_callback_handler(callback: CallbackQuery):
    await callback.answer()
    action = callback.data.split(":")[1]
    user_id = callback.from_user.id
    if not is_admin(user_id):
        await callback.message.answer("⛔ Только для админов.")
        return

    if action == "init":
        me = await callback.bot.get_me()
        url = f"https://t.me/{me.username}?start=register"
        kb = InlineKeyboardMarkup(inline_keyboard=[
            [InlineKeyboardButton(text="📝 Зарегистрироваться", url=url)]
        ])
        await callback.bot.send_message(
            chat_id=GROUP_CHAT_ID,
            text=("🏍 Добро пожаловать в моточат!\n\n"
                  "Чтобы зарегистрироваться, нажмите кнопку ниже — бот откроется в личке."),
            reply_markup=kb,
        )
        await callback.message.answer("✅ Кнопка регистрации отправлена в группу.")
        logger.info("Admin %s sent init message to group", user_id)

    elif action == "participants":
        await show_participants_panel(callback.message)
    elif action == "stats_bikes":
        await stats_bikes_callback(callback)
    elif action == "detailed_list":
        await detailed_list_callback(callback)

    elif action == "bd_all":
        birthdays = get_all_birthdays_sorted()
        if not birthdays:
            await callback.message.answer("📭 В базе нет данных о днях рождения.")
            return
        response = "🎂 Дни рождения участников:\n\n"
        for b in birthdays:
            response += f"• {b['name']} (@{b['username'] or 'нет юзернейма'}) — {b['birthday']}\n"
        await callback.message.answer(response)

    elif action == "bd_soon":
        upcoming = get_upcoming_birthdays(days=30)
        if not upcoming:
            await callback.message.answer("🎉 Ближайших дней рождения в течение 30 дней нет.")
            return
        response = "🎂 Ближайшие дни рождения (в течение 30 дней):\n\n"
        for b in upcoming:
            response += f"• {b['name']} (@{b['username'] or 'нет юзернейма'}) — {b['birthday']} (через {b['days_left']} дн.)\n"
        await callback.message.answer(response)

    elif action == "weather_on":
        set_setting("weather_broadcast_enabled", "true")
        await callback.message.answer("✅ Рассылка прогноза погоды включена.")

    elif action == "weather_off":
        set_setting("weather_broadcast_enabled", "false")
        await callback.message.answer("❌ Рассылка прогноза погоды выключена.")

    elif action == "mute":
        await callback.message.answer("Используйте команду /mute_user в ЛС.")

    elif action == "new_ride":
        await callback.message.answer(
            "Для создания планового заезда используйте команду `/new_ride` в ЛС.\n"
            "Бот попросит ввести название, дату, время, место и описание."
        )
    elif action == "end_ride":
        await callback.message.answer(
            "Для отмены планового заезда используйте команду `/end_ride <id_заезда>` в ЛС.\n"
            "ID заезда можно узнать командой `/rides`."
        )

@router.callback_query(F.data == "admin:stats_bikes")
async def stats_bikes_callback(callback: CallbackQuery):
    await callback.answer()
    # Группировка по марке и модели
    from sqlalchemy import func
    with get_session() as session:
        bikes = session.query(User.bike_brand, User.bike_model, func.count(User.id)).filter(
            User.bike_brand.isnot(None), User.bike_model.isnot(None)
        ).group_by(User.bike_brand, User.bike_model).all()
    if not bikes:
        await callback.message.answer("📭 Данных о мотоциклах пока нет.")
        return
    text = "🏍 *Статистика мотоциклов:*\n\n"
    for brand, model, count in bikes:
        text += f"• {brand} {model} — {count} шт.\n"
    await callback.message.answer(text, parse_mode="Markdown")

@router.callback_query(F.data == "admin:detailed_list")
async def detailed_list_callback(callback: CallbackQuery):
    await callback.answer()
    users = get_all_users()
    if not users:
        await callback.message.answer("📭 Пока нет зарегистрированных участников.")
        return
    response = "📋 *Список участников:*\n\n"
    for u in users:
        response += f"• {u['name']} (@{u['username'] or 'нет юзернейма'})\n"
        response += f"  🏍 {u['bike']}\n"
    # Если сообщение слишком длинное, разбиваем
    if len(response) > 4000:
        # можно разбить на части или отправить файлом
        await callback.message.answer("Слишком длинный список, отправляю файлом.")
        # альтернатива: отправить текстовым файлом
        import io
        file = io.BytesIO(response.encode())
        await callback.bot.send_document(callback.from_user.id, document=file, filename="participants.txt")
    else:
        await callback.message.answer(response, parse_mode=None)


@router.message(Command("test_weather"))
async def test_weather(message: Message):
    if not is_admin(message.from_user.id):
        await message.answer("⛔ Только для админов.")
        return
    from utils.weather_scheduler import send_weather_to_group, send_weather_to_users
    await send_weather_to_group(message.bot, is_morning=True)
    await send_weather_to_users(message.bot, is_morning=True)
    await message.answer("✅ Тестовая рассылка погоды выполнена. Проверьте группу и личные сообщения.")


router = Router(name="wash_admin")
def is_admin(uid: int) -> bool:
    return uid in ADMIN_IDS

# FSM для настройки услуги
class WashSetupStates(StatesGroup):
    waiting_description = State()
    waiting_price = State()
    waiting_provider_name = State()
    waiting_provider_phone = State()
    waiting_provider_tg_id = State()
    waiting_photo = State()

# FSM для настройки расписания
class WashScheduleStates(StatesGroup):
    waiting_day = State()
    waiting_start_time = State()
    waiting_end_time = State()
    waiting_duration = State()

@router.callback_query(F.data == "admin:wash_setup")
async def wash_setup(callback: CallbackQuery, state: FSMContext):
    if not is_admin(callback.from_user.id):
        await callback.answer("⛔ Только для админов.", show_alert=True)
        return
    await callback.answer()
    with get_session() as session:
        service = session.query(WashService).first()
        if service:
            text = f"Текущая услуга:\n{service.description}\nЦена: {service.price} руб.\nИсполнитель: {service.provider_name}, тел. {service.provider_phone}, TG ID: {service.provider_tg_id}"
            if service.photos:
                text += "\nФото загружены."
            kb = InlineKeyboardMarkup(inline_keyboard=[
                [InlineKeyboardButton(text="✏️ Изменить описание", callback_data="admin:wash_edit_desc")],
                [InlineKeyboardButton(text="💰 Изменить цену", callback_data="admin:wash_edit_price")],
                [InlineKeyboardButton(text="👤 Изменить исполнителя", callback_data="admin:wash_edit_provider")],
                [InlineKeyboardButton(text="🖼 Добавить фото", callback_data="admin:wash_photo")],
                [InlineKeyboardButton(text="🗑 Удалить услугу", callback_data="admin:wash_delete")]
            ])
            await callback.message.answer(text, reply_markup=kb, parse_mode="Markdown")
        else:
            await callback.message.answer("Настройка новой услуги.\nВведите описание (адрес, что входит, контакты и т.п.):")
            await state.set_state(WashSetupStates.waiting_description)

@router.message(WashSetupStates.waiting_description)
async def wash_desc(message: Message, state: FSMContext):
    await state.update_data(description=message.text)
    await message.answer("Введите стоимость мойки (в рублях):")
    await state.set_state(WashSetupStates.waiting_price)

@router.message(WashSetupStates.waiting_price)
async def wash_price(message: Message, state: FSMContext):
    if not message.text.isdigit():
        await message.answer("Введите число.")
        return
    await state.update_data(price=int(message.text))
    await message.answer("Введите имя исполнителя (например, Анатолий):")
    await state.set_state(WashSetupStates.waiting_provider_name)

@router.message(WashSetupStates.waiting_provider_name)
async def wash_provider_name(message: Message, state: FSMContext):
    await state.update_data(provider_name=message.text)
    await message.answer("Введите телефон исполнителя:")
    await state.set_state(WashSetupStates.waiting_provider_phone)

@router.message(WashSetupStates.waiting_provider_phone)
async def wash_provider_phone(message: Message, state: FSMContext):
    await state.update_data(provider_phone=message.text)
    await message.answer("Введите Telegram ID исполнителя (цифры):")
    await state.set_state(WashSetupStates.waiting_provider_tg_id)

@router.message(WashSetupStates.waiting_provider_tg_id)
async def wash_provider_tg_id(message: Message, state: FSMContext):
    if not message.text.isdigit():
        await message.answer("Введите числовой ID.")
        return
    await state.update_data(provider_tg_id=int(message.text))
    data = await state.get_data()
    with get_session() as session:
        service = WashService(
            name="Мойка",
            description=data['description'],
            price=data['price'],
            provider_name=data['provider_name'],
            provider_phone=data['provider_phone'],
            provider_tg_id=data['provider_tg_id'],
            is_active=True
        )
        session.add(service)
        session.commit()
        await state.clear()
        await message.answer("✅ Услуга создана. Теперь можно загрузить фото (команда /add_wash_photo) или настроить расписание через админ-панель.")


@router.message(Command("add_wash_photo"))
async def add_wash_photo(message: Message, state: FSMContext):
    if not is_admin(message.from_user.id):
        await message.answer("⛔ Только для админов.")
        return
    await message.answer("Отправьте фото (можно несколько, каждое отдельным сообщением). После отправки всех фото напишите /done")
    await state.set_state(WashSetupStates.waiting_photo)
    await state.update_data(photos=[])

@router.message(WashSetupStates.waiting_photo)
async def save_photo(message: Message, state: FSMContext):
    if message.text == "/done":
        data = await state.get_data()
        photos = data.get('photos', [])
        with get_session() as session:
            service = session.query(WashService).first()
            if service:
                service.photos = ','.join(photos)
                session.commit()
        await state.clear()
        await message.answer("✅ Фото сохранены.")
        return
    if message.photo:
        file_id = message.photo[-1].file_id
        data = await state.get_data()
        photos = data.get('photos', [])
        photos.append(file_id)
        await state.update_data(photos=photos)
        await message.answer("Фото добавлено. Отправьте ещё или /done")
    else:
        await message.answer("Отправьте фото или /done")


@router.callback_query(F.data == "admin:wash_schedule")
async def wash_schedule_menu(callback: CallbackQuery):
    if not is_admin(callback.from_user.id):
        await callback.answer("⛔ Только для админов.", show_alert=True)
        return
    await callback.answer()
    # Показать список дней для выбора
    days = ["Пн", "Вт", "Ср", "Чт", "Пт", "Сб", "Вс"]
    kb = InlineKeyboardMarkup(inline_keyboard=[
        [InlineKeyboardButton(text=day, callback_data=f"wash_day:{i}")] for i, day in enumerate(days)
    ])
    await callback.message.answer("Выберите день недели:", reply_markup=kb)

@router.callback_query(F.data.startswith("wash_day:"))
async def wash_schedule_day(callback: CallbackQuery, state: FSMContext):
    day = int(callback.data.split(":")[1])
    await state.update_data(day=day)
    await callback.message.answer("Введите время начала (например, 10:00):")
    await state.set_state(WashScheduleStates.waiting_start_time)
    await callback.answer()

@router.message(WashScheduleStates.waiting_start_time)
async def wash_schedule_start(message: Message, state: FSMContext):
    # простая валидация формата HH:MM
    await state.update_data(start_time=message.text.strip())
    await message.answer("Введите время окончания (например, 18:00):")
    await state.set_state(WashScheduleStates.waiting_end_time)

@router.message(WashScheduleStates.waiting_end_time)
async def wash_schedule_end(message: Message, state: FSMContext):
    await state.update_data(end_time=message.text.strip())
    data = await state.get_data()
    with get_session() as session:
        service = session.query(WashService).first()
        if service:
            schedule = WashSchedule(
                service_id=service.id,
                day_of_week=data['day'],
                start_time=data['start_time'],
                end_time=data['end_time'],
                slot_duration_min=60
            )
            session.add(schedule)
            session.commit()
            await message.answer(f"✅ Расписание на {['Пн','Вт','Ср','Чт','Пт','Сб','Вс'][data['day']]} добавлено.")
        else:
            await message.answer("❌ Сначала создайте услугу через /admin_panel -> Настроить мойку.")
    await state.clear()



@router.callback_query(F.data.startswith("admin:"))
async def admin_callback_handler(callback: CallbackQuery):
    await callback.answer()
    action = callback.data.split(":")[1]
    user_id = callback.from_user.id
    if not is_admin(user_id):
        await callback.message.answer("⛔ Только для админов.")
        return

    if action == "init":
        me = await callback.bot.get_me()
        url = f"https://t.me/{me.username}?start=register"
        kb = InlineKeyboardMarkup(inline_keyboard=[
            [InlineKeyboardButton(text="📝 Зарегистрироваться", url=url)]
        ])
        await callback.bot.send_message(
            chat_id=GROUP_CHAT_ID,
            text=("🏍 Добро пожаловать в моточат!\n\n"
                  "Чтобы зарегистрироваться, нажмите кнопку ниже — бот откроется в личке."),
            reply_markup=kb,
        )
        await callback.message.answer("✅ Кнопка регистрации отправлена в группу.")
        logger.info("Admin %s sent init message to group", user_id)

    elif action == "participants":
        users = get_all_users()
        if not users:
            await callback.message.answer("📭 Пока нет зарегистрированных участников.")
            return
        response = "📋 Список участников:\n\n"
        for u in users:
            response += f"• {u['name']} (@{u['username'] or 'нет юзернейма'})\n"
            response += f"  🏍 {u['bike']}\n"
        await callback.message.answer(response)

    elif action == "bd_all":
        birthdays = get_all_birthdays_sorted()
        if not birthdays:
            await callback.message.answer("📭 В базе нет данных о днях рождения.")
            return
        response = "🎂 Дни рождения участников:\n\n"
        for b in birthdays:
            response += f"• {b['name']} (@{b['username'] or 'нет юзернейма'}) — {b['birthday']}\n"
        await callback.message.answer(response)

    elif action == "bd_soon":
        upcoming = get_upcoming_birthdays(days=30)
        if not upcoming:
            await callback.message.answer("🎉 Ближайших дней рождения в течение 30 дней нет.")
            return
        response = "🎂 Ближайшие дни рождения (в течение 30 дней):\n\n"
        for b in upcoming:
            response += f"• {b['name']} (@{b['username'] or 'нет юзернейма'}) — {b['birthday']} (через {b['days_left']} дн.)\n"
        await callback.message.answer(response)

    elif action == "weather_on":
        set_setting("weather_broadcast_enabled", "true")
        await callback.message.answer("✅ Рассылка прогноза погоды включена.")

    elif action == "weather_off":
        set_setting("weather_broadcast_enabled", "false")
        await callback.message.answer("❌ Рассылка прогноза погоды выключена.")

    elif action == "mute":
        await callback.message.answer("Используйте команду /mute_user в ЛС.")
    else:
        await callback.message.answer("Неизвестное действие.")
